<!-- Preferred single-definition-to-word card, based on example phrases -->
<!-- [[REFERENCE_TEXT]] -->
{{#Definition[[INDEX]]_NativeText}}
    <div class="dictionary-note nt2lt front">
        <div class="top">
            <div class="text native">
                <div class="main">{{Definition[[INDEX]]_NativeText}}</div>
                {{#Definition[[INDEX]]_AltNativeText}}
                    <div class="alt">{{Definition[[INDEX]]_AltNativeText}}</div>
                {{/Definition[[INDEX]]_AltNativeText}}
            </div>
            <div class="context">
                <span class="languages">{{NativeLang}} ⟶ {{LearningLang}}</span>
            </div>
        </div>
    </div>
{{/Definition[[INDEX]]_NativeText}}
