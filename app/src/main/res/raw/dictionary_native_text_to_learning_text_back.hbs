<!-- Preferred single-definition-to-word card, based on example phrases -->
<!-- [[REFERENCE_TEXT]] -->
{{#Definition[[INDEX]]_NativeText}}
    <div class="dictionary-note nt2lt back">
        <div class="top">
            <div class="text native">
                <div class="main">{{Definition[[INDEX]]_NativeText}}</div>
                {{#Definition[[INDEX]]_AltNativeText}}
                    <div class="alt">{{Definition[[INDEX]]_AltNativeText}}</div>
                {{/Definition[[INDEX]]_AltNativeText}}
            </div>
            <div class="context">
                <span class="languages">{{NativeLang}} ⟶ {{LearningLang}}</span>
            </div>
        </div>

        <hr id="answer"/>

        <div class="bottom">
            <div class="text learning">
                <div class="main">{{Definition[[INDEX]]_LearningText}}</div>
                {{#Definition[[INDEX]]_AltLearningText}}
                    <div class="alt">{{Definition[[INDEX]]_AltLearningText}}</div>
                {{/Definition[[INDEX]]_AltLearningText}}
            </div>

            <div class="definition-box">
                <div class="learning-word">
                    {{#SourceUrl}}<a href="{{SourceUrl}}">{{LearningWord}}</a>{{/SourceUrl}}
                    {{^SourceUrl}}{{LearningWord}}{{/SourceUrl}}
                </div>
                {{#IPA}}
                    <div class="ipa">{{IPA}}</div>
                {{/IPA}}
                <div class="context">
                    <span class="pos">{{POS}}</span>
                </div>
                <div class="definition">{{Definition[[INDEX]]}}</div>
                {{#Definition[[INDEX]]_WordSynonyms}}
                    <div class="synonyms"><span class="label">≈</span> {{Definition[[INDEX]]_WordSynonyms}}</div>
                {{/Definition[[INDEX]]_WordSynonyms}}
            </div>

            {{#PersonalNotes}}
                <div class="personal-notes">
                    {{PersonalNotes}}
                </div>
            {{/PersonalNotes}}

            {{#Audio}}<div class="audio">{{Audio}}</div>{{/Audio}}
        </div>
    </div>
{{/Definition[[INDEX]]_NativeText}}
