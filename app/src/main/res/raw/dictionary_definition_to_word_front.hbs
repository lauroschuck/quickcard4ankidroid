{{#Definition[[INDEX]]}}
    <div class="dictionary-note d2w front">
        <div class="top">
            <div class="definition">{{Definition[[INDEX]]}}</div>
            <div class="context">
                <span class="lexical-cat">{{LexicalCat}}</span>
                <span class="lang-code">{{LearningLang}}</span>
            </div>

            {{#Definition[[INDEX]]_NativeText}}
                <div class="text native">
                    <div class="main">{{Definition[[INDEX]]_NativeText}}</div>
                    {{#Definition[[INDEX]]_AltNativeText}}
                        <div class="alt">[{{Definition[[INDEX]]_AltNativeText}}]</div>
                    {{/Definition[[INDEX]]_AltNativeText}}
                </div>
            {{/Definition[[INDEX]]_NativeText}}
        </div>
    </div>
{{/Definition[[INDEX]]}}
