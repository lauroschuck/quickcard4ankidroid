<!-- Alternative single-definition-to-word card, directly based on definition when no example phrase is available -->
<!-- [[REFERENCE_TEXT]] -->
{{#Definition[[INDEX]]}}
    {{^Definition[[INDEX]]_NativeText}}
        <div class="dictionary-note d2w front">
            <div class="top">
                <div class="definition">{{Definition[[INDEX]]}}</div>
                <div class="context">
                    <span class="lexical-cat">{{LexicalCat}}</span>
                </div>
            </div>
        </div>
    {{/Definition[[INDEX]]_NativeText}}
{{/Definition[[INDEX]]}}
