<!-- Individual native-to-learning-text card, not grouped under a single headword -->
<!-- [[REFERENCE_TEXT]] -->
<div class="text-note nt2lt back">
    <div class="top">
        <div class="text native">
            <div class="main">{{NativeText}}</div>
            {{#AltNativeText}}
                <div class="alt">{{AltNativeText}}</div>
            {{/AltNativeText}}
        </div>
        <div class="context">
            <span class="languages">{{NativeLang}} ⟶ {{LearningLang}}</span>
        </div>
    </div>

    <hr id="answer"/>

    <div class="bottom">
        <div class="text learning">
            <div class="main">{{LearningText}}</div>
            {{#AltLearningText}}
                <div class="alt">{{AltLearningText}}</div>
            {{/AltLearningText}}
        </div>

        <div class="definition-box">
            {{#LearningWord}}
                <div class="learning-word">
                    {{#SourceUrl}}<a href="{{SourceUrl}}">{{LearningWord}}</a>{{/SourceUrl}}
                    {{^SourceUrl}}{{LearningWord}}{{/SourceUrl}}
                </div>
            {{/LearningWord}}
            {{#IPA}}
                <div class="ipa">{{IPA}}</div>
            {{/IPA}}
            <div class="context">
                <span class="pos">{{POS}}</span>
            </div>
            {{#Definition}}
                <div class="definition">{{Definition}}</div>
            {{/Definition}}
            {{#WordSynonyms}}
                <div class="synonyms"><span class="label">≈</span> {{WordSynonyms}}</div>
            {{/WordSynonyms}}
        </div>

        {{#PersonalNotes}}
            <div class="personal-notes">
                {{PersonalNotes}}
            </div>
        {{/PersonalNotes}}

        {{#Audio}}<div class="audio">{{Audio}}</div>{{/Audio}}

        {{^LearningWord}}
            {{#SourceUrl}}
                <a href="{{SourceUrl}}" class="source-url">Source</a>
            {{/SourceUrl}}
        {{/LearningWord}}
    </div>
</div>
