<resources>
    <!-- Base application theme using semantic names -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/header_primary</item>
        <item name="colorPrimaryVariant">@color/header_secondary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorAccent">@color/anki_blue</item>
        <item name="colorSecondary">@color/anki_blue</item>
        <item name="colorSecondaryVariant">@color/anki_blue_variant</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorControlActivated">@color/anki_blue</item>
        <item name="snackbarStyle">@style/Widget.App.Snackbar</item>
        <item name="materialAlertDialogTheme">@style/AppTheme.MaterialAlertDialog</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="AppTheme.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/accent_primary</item>
    </style>

    <!-- Specific theme for Settings -->
    <style name="SettingsTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/header_primary</item>
        <item name="colorPrimaryVariant">@color/header_secondary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorAccent">@color/anki_blue</item>
        <item name="colorSecondary">@color/anki_blue</item>
        <item name="colorSecondaryVariant">@color/anki_blue_variant</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorControlActivated">@color/anki_blue</item>
        <item name="snackbarStyle">@style/Widget.App.Snackbar</item>
        <item name="materialAlertDialogTheme">@style/AppTheme.MaterialAlertDialog</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Specific theme for Open Source Licenses -->
    <style name="LicensesTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/header_primary</item>
        <item name="colorPrimaryVariant">@color/header_secondary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="snackbarStyle">@style/Widget.App.Snackbar</item>
        <item name="materialAlertDialogTheme">@style/AppTheme.MaterialAlertDialog</item>
        <item name="android:windowBackground">@color/app_background</item>
    </style>

    <style name="Widget.App.Snackbar" parent="Widget.MaterialComponents.Snackbar">
        <item name="animationMode">slide</item>
    </style>
</resources>