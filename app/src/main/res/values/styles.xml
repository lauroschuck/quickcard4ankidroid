<resources>
    <!-- Base application theme using Anki branding colors -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary branding color (Anki Star Blue) -->
        <item name="colorPrimary">@color/anki_blue</item>
        <!-- Status bar color -->
        <item name="colorPrimaryDark">#0086d1</item>
        <!-- Accent color for checkboxes and active elements -->
        <item name="colorAccent">@color/anki_blue</item>
        <!-- Background color resembling the Anki Note -->
        <item name="android:windowBackground">@color/anki_note</item>
    </style>
</resources>